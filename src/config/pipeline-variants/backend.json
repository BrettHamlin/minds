{
  "version": "3.1",
  "transport": "bus",
  "codeReview": {
    "enabled": true,
    "model": "claude-opus-4-6",
    "maxAttempts": 3
  },
  "phases": {
    "clarify": {
      "command": "/collab.clarify",
      "signals": ["CLARIFY_COMPLETE", "CLARIFY_QUESTION", "CLARIFY_ERROR", "CLARIFY_QUESTIONS"],
      "transitions": { "CLARIFY_COMPLETE": { "to": "spec_critique" } }
    },
    "spec_critique": {
      "command": "/collab.spec-critique",
      "signals": ["SPEC_CRITIQUE_COMPLETE", "SPEC_CRITIQUE_FAILED", "SPEC_CRITIQUE_QUESTION", "SPEC_CRITIQUE_QUESTIONS", "SPEC_CRITIQUE_PROCESSING"],
      "transitions": {
        "SPEC_CRITIQUE_COMPLETE": { "to": "plan" },
        "SPEC_CRITIQUE_FAILED": { "to": "clarify" }
      }
    },
    "plan": {
      "command": "/collab.plan",
      "signals": ["PLAN_COMPLETE", "PLAN_ERROR"],
      "transitions": { "PLAN_COMPLETE": { "to": "plan_review" } }
    },
    "plan_review": {
      "command": "/collab.plan",
      "signals": ["PLAN_REVIEW_APPROVED", "PLAN_REVIEW_REJECTED", "PLAN_REVIEW_COMPLETE"],
      "transitions": {
        "PLAN_REVIEW_APPROVED": { "to": "tasks" },
        "PLAN_REVIEW_REJECTED": { "to": "plan" },
        "PLAN_REVIEW_COMPLETE": { "to": "tasks" }
      }
    },
    "tasks": {
      "command": "/collab.tasks",
      "signals": ["TASKS_COMPLETE", "TASKS_ERROR"],
      "transitions": { "TASKS_COMPLETE": { "to": "analyze" } }
    },
    "analyze": {
      "command": "/collab.analyze",
      "signals": ["ANALYZE_COMPLETE", "ANALYZE_ERROR", "ANALYZE_QUESTIONS"],
      "transitions": { "ANALYZE_COMPLETE": { "to": "analyze_review" } }
    },
    "analyze_review": {
      "command": "/collab.analyze",
      "signals": ["ANALYZE_REVIEW_APPROVED", "ANALYZE_REVIEW_REJECTED", "ANALYZE_REVIEW_COMPLETE"],
      "transitions": {
        "ANALYZE_REVIEW_APPROVED": { "to": "implement" },
        "ANALYZE_REVIEW_REJECTED": { "to": "analyze" },
        "ANALYZE_REVIEW_COMPLETE": { "to": "implement" }
      }
    },
    "implement": {
      "command": "/collab.implement",
      "signals": ["IMPLEMENT_COMPLETE", "IMPLEMENT_WAITING", "IMPLEMENT_ERROR"],
      "transitions": {
        "IMPLEMENT_COMPLETE": { "to": "run_tests" },
        "IMPLEMENT_ERROR": { "to": "implement" }
      }
    },
    "run_tests": {
      "command": "/collab.run-tests",
      "signals": ["RUN_TESTS_COMPLETE", "RUN_TESTS_FAILED", "RUN_TESTS_ERROR"],
      "transitions": {
        "RUN_TESTS_COMPLETE": { "to": "blindqa" },
        "RUN_TESTS_FAILED": { "to": "run_tests" },
        "RUN_TESTS_ERROR": { "to": "escalate" }
      }
    },
    "blindqa": {
      "command": "/collab.blindqa",
      "signals": ["BLINDQA_COMPLETE", "BLINDQA_FAILED", "BLINDQA_ERROR", "BLINDQA_QUESTION", "BLINDQA_WAITING", "BLINDQA_PROCESSING"],
      "transitions": {
        "BLINDQA_COMPLETE": { "to": "done" },
        "BLINDQA_FAILED": { "to": "implement" }
      }
    },
    "escalate": { "terminal": true },
    "done": { "terminal": true }
  }
}
