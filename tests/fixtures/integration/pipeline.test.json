{
  "_description": "Synthetic single-agent integration test. Tests SC-003: all transitions fire from config, phase_history accumulates correctly, terminal phase reached without manual intervention.",
  "_test_scenario": {
    "name": "3-phase generic pipeline",
    "signals": ["INIT_COMPLETE", "WORK_COMPLETE", "REVIEW_COMPLETE"],
    "expected_phase_history_count": 3,
    "expected_terminal_phase": "done",
    "verifies": ["SC-003", "FR-004", "FR-006"]
  },
  "mock_pipeline": {
    "version": "3.0",
    "phases": [
      {
        "id": "init",
        "command": "/collab.init",
        "signals": ["INIT_COMPLETE", "INIT_FAILED"]
      },
      {
        "id": "work",
        "command": "/collab.work",
        "signals": ["WORK_COMPLETE", "WORK_FAILED"]
      },
      {
        "id": "review",
        "command": "/collab.review",
        "signals": ["REVIEW_COMPLETE", "REVIEW_FAILED"]
      },
      {
        "id": "done",
        "terminal": true,
        "signals": []
      }
    ],
    "transitions": [
      {"from": "init",   "signal": "INIT_COMPLETE",   "to": "work"},
      {"from": "work",   "signal": "WORK_COMPLETE",   "to": "review"},
      {"from": "review", "signal": "REVIEW_COMPLETE", "to": "done"},
      {"from": "init",   "signal": "INIT_FAILED",     "to": "init"},
      {"from": "work",   "signal": "WORK_FAILED",     "to": "work"},
      {"from": "review", "signal": "REVIEW_FAILED",   "to": "review"}
    ]
  },
  "simulation_steps": [
    {
      "step": 1,
      "action": "send_signal",
      "from_phase": "init",
      "signal": "INIT_COMPLETE",
      "expected_transition_source": "transitions[0]",
      "expected_next_phase": "work",
      "expected_phase_history_entry": {"phase": "init", "signal": "INIT_COMPLETE"}
    },
    {
      "step": 2,
      "action": "send_signal",
      "from_phase": "work",
      "signal": "WORK_COMPLETE",
      "expected_transition_source": "transitions[1]",
      "expected_next_phase": "review",
      "expected_phase_history_entry": {"phase": "work", "signal": "WORK_COMPLETE"}
    },
    {
      "step": 3,
      "action": "send_signal",
      "from_phase": "review",
      "signal": "REVIEW_COMPLETE",
      "expected_transition_source": "transitions[2]",
      "expected_next_phase": "done",
      "expected_phase_history_entry": {"phase": "review", "signal": "REVIEW_COMPLETE"}
    }
  ],
  "assertions": [
    {
      "id": "A1",
      "description": "phase_history has exactly 3 entries after 3 signals",
      "check": "len(registry.phase_history) == 3"
    },
    {
      "id": "A2",
      "description": "Each transition fired from config (not hardcoded logic)",
      "check": "all transitions resolved via pipeline.json transitions array"
    },
    {
      "id": "A3",
      "description": "Final phase is done (terminal: true)",
      "check": "registry.current_step == 'done'"
    },
    {
      "id": "A4",
      "description": "No hardcoded phase names used as routing conditions",
      "check": "SC-002 grep returns zero matches in collab.run.md"
    }
  ]
}
