{
  "name": "deploy-pack",
  "type": "pack",
  "version": "1.0.0",
  "description": "Full deployment pack — spec through post-deploy verification",
  "author": "Brett Hamlin",
  "repository": "https://github.com/BrettHamlin/collab-registry",
  "pipelines": ["specify", "plan", "run-tests", "visual-verify", "pre-deploy-confirm", "deploy-verify"],
  "dependencies": [
    { "name": "specify", "version": ">=1.0.0" },
    { "name": "plan", "version": ">=1.0.0" },
    { "name": "run-tests", "version": ">=1.0.0" },
    { "name": "visual-verify", "version": ">=1.0.0" },
    { "name": "pre-deploy-confirm", "version": ">=1.0.0" },
    { "name": "deploy-verify", "version": ">=1.0.0" }
  ],
  "cliDependencies": [
    { "name": "bun", "version": ">=1.0.0", "required": true, "installHint": "curl -fsSL https://bun.sh/install | bash" },
    { "name": "jq", "version": ">=1.6.0", "required": true, "installHint": "brew install jq" }
  ],
  "commands": [],
  "checksum": "deploy-pack-checksum"
}
