{
  "name": "collab",
  "version": "0.1.0",
  "description": "AI-powered spec creation platform for structured team development",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "bun test tests/",
    "test:minds": "bun test minds/",
    "test:all": "bun test",
    "test:unit": "bun test tests/unit/ minds/*/lib/ minds/lib/",
    "test:fast": "bun test tests/unit/ minds/*/lib/ minds/lib/",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts"
  },
  "keywords": [
    "ai",
    "spec",
    "slack",
    "jira",
    "linear",
    "product-management"
  ],
  "author": "Brett Hamlin",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@slack/bolt": "^3.18.0",
    "@xenova/transformers": "^2.17.2",
    "commander": "^14.0.3",
    "dotenv": "^16.4.1",
    "drizzle-orm": "^0.45.1",
    "express": "^4.18.2",
    "marked": "^17.0.2",
    "node-llama-cpp": "^3.17.1",
    "openai": "^6.22.0",
    "pg": "^8.11.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.5",
    "@types/pg": "^8.11.0",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "ajv": "^8.18.0",
    "ajv-cli": "^5.0.0",
    "drizzle-kit": "^0.31.9",
    "eslint": "^8.56.0",
    "prettier": "^3.2.4",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "workspaces": ["cli"]
}
