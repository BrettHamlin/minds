{
  "version": "3.1",
  "transport": "bus",
  "phases": {
    "clarify": {
      "command": "/collab.clarify",
      "signals": [
        "CLARIFY_COMPLETE",
        "CLARIFY_QUESTION",
        "CLARIFY_ERROR",
        "CLARIFY_QUESTIONS"
      ],
      "transitions": {
        "CLARIFY_COMPLETE": {
          "to": "plan"
        },
        "CLARIFY_ERROR": {
          "to": "clarify"
        }
      },
      "model": "claude-opus-4-6",
      "inputs": [
        "ticket_spec",
        "clarify_output"
      ],
      "outputs": [
        "clarify_output"
      ]
    },
    "plan": {
      "command": "/collab.plan",
      "signals": [
        "PLAN_COMPLETE",
        "PLAN_ERROR"
      ],
      "transitions": {
        "PLAN_COMPLETE": {
          "gate": "plan_review"
        },
        "PLAN_ERROR": {
          "to": "plan"
        }
      },
      "model": "claude-sonnet-4-6",
      "inputs": [
        "ticket_spec",
        "clarify_output",
        "plan_output"
      ],
      "outputs": [
        "plan_output"
      ]
    },
    "tasks": {
      "command": "/collab.tasks",
      "signals": [
        "TASKS_COMPLETE",
        "TASKS_ERROR"
      ],
      "transitions": {
        "TASKS_COMPLETE": {
          "to": "analyze"
        },
        "TASKS_ERROR": {
          "to": "tasks"
        }
      },
      "model": "claude-sonnet-4-6",
      "inputs": [
        "ticket_spec",
        "tasks_output",
        "implement_output"
      ],
      "outputs": [
        "tasks_output"
      ]
    },
    "analyze": {
      "command": "/collab.analyze",
      "signals": [
        "ANALYZE_COMPLETE",
        "ANALYZE_ERROR",
        "ANALYZE_QUESTIONS"
      ],
      "transitions": {
        "ANALYZE_COMPLETE": {
          "gate": "analyze_review"
        },
        "ANALYZE_ERROR": {
          "to": "analyze"
        }
      },
      "model": "claude-sonnet-4-6",
      "inputs": [
        "ticket_spec",
        "tasks_output",
        "analyze_output",
        "implement_output"
      ],
      "outputs": [
        "analyze_output"
      ]
    },
    "implement": {
      "actions": [
        {
          "display": "Starting implement phase for ${TICKET_ID}: ${TICKET_TITLE}"
        },
        {
          "command": "/collab.implement"
        }
      ],
      "signals": [
        "IMPLEMENT_COMPLETE",
        "IMPLEMENT_WAITING",
        "IMPLEMENT_ERROR"
      ],
      "transitions": {
        "IMPLEMENT_ERROR": {
          "to": "implement"
        }
      },
      "conditionalTransitions": [
        {
          "signal": "IMPLEMENT_COMPLETE",
          "if": "hasGroup",
          "to": "tasks"
        },
        {
          "signal": "IMPLEMENT_COMPLETE",
          "to": "run_tests"
        }
      ],
      "model": "claude-sonnet-4-6",
      "inputs": [
        "ticket_spec",
        "implement_output"
      ],
      "outputs": [
        "implement_output"
      ]
    },
    "run_tests": {
      "command": "/collab.run-tests",
      "signals": [
        "RUN_TESTS_COMPLETE",
        "RUN_TESTS_FAILED",
        "RUN_TESTS_ERROR"
      ],
      "transitions": {
        "RUN_TESTS_COMPLETE": {
          "to": "visual_verify"
        },
        "RUN_TESTS_FAILED": {
          "to": "run_tests"
        },
        "RUN_TESTS_ERROR": {
          "to": "run_tests"
        }
      },
      "model": "claude-sonnet-4-6",
      "inputs": [
        "ticket_spec",
        "implement_output",
        "run_tests_output"
      ],
      "outputs": [
        "run_tests_output"
      ]
    },
    "visual_verify": {
      "command": "/collab.visual-verify",
      "signals": [
        "VISUAL_VERIFY_COMPLETE",
        "VISUAL_VERIFY_FAILED",
        "VISUAL_VERIFY_ERROR"
      ],
      "transitions": {
        "VISUAL_VERIFY_COMPLETE": {
          "to": "blindqa"
        },
        "VISUAL_VERIFY_FAILED": {
          "to": "visual_verify"
        },
        "VISUAL_VERIFY_ERROR": {
          "to": "visual_verify"
        }
      },
      "model": "claude-sonnet-4-6",
      "inputs": [
        "ticket_spec",
        "implement_output",
        "run_tests_output",
        "visual_verify_output"
      ],
      "outputs": [
        "visual_verify_output"
      ]
    },
    "blindqa": {
      "actions": [
        {
          "display": "${TICKET_ID} — Starting Blind QA verification phase"
        },
        {
          "command": "/collab.blindqa"
        }
      ],
      "signals": [
        "BLINDQA_COMPLETE",
        "BLINDQA_FAILED",
        "BLINDQA_ERROR",
        "BLINDQA_QUESTION",
        "BLINDQA_WAITING"
      ],
      "goal_gate": "always",
      "orchestrator_context": ".collab/config/orchestrator-contexts/blindqa.md",
      "transitions": {
        "BLINDQA_COMPLETE": {
          "to": "done"
        },
        "BLINDQA_FAILED": {
          "to": "blindqa"
        },
        "BLINDQA_ERROR": {
          "to": "blindqa"
        }
      },
      "model": "claude-sonnet-4-6",
      "inputs": [
        "ticket_spec",
        "implement_output",
        "run_tests_output",
        "visual_verify_output",
        "blindqa_output"
      ],
      "outputs": [
        "blindqa_output"
      ]
    },
    "done": {
      "terminal": true
    }
  },
  "defaultModel": "claude-sonnet-4-6",
  "gates": {
    "plan_review": {
      "prompt": ".collab/config/gates/plan.md",
      "on": {
        "APPROVED": {
          "to": "tasks"
        },
        "REVISION_NEEDED": {
          "to": "plan",
          "feedback": "enrich",
          "maxRetries": 3,
          "onExhaust": "skip"
        }
      },
      "skipTo": "tasks"
    },
    "analyze_review": {
      "prompt": ".collab/config/gates/analyze.md",
      "on": {
        "REMEDIATION_COMPLETE": {
          "to": "implement"
        },
        "ESCALATION": {
          "feedback": "raw",
          "onExhaust": "abort"
        }
      }
    }
  },
  "codeReview": {
    "enabled": true,
    "model": "claude-opus-4-6",
    "maxAttempts": 3
  }
}
