{
  "version": "3.1",
  "transport": "bus",
  "description": "Stage 2: Single phase — verify signal emission through bus (clarify→done)",
  "phases": {
    "clarify": {
      "command": "/collab.clarify",
      "signals": ["CLARIFY_COMPLETE", "CLARIFY_QUESTION", "CLARIFY_ERROR"],
      "transitions": {
        "CLARIFY_COMPLETE": { "to": "done" }
      }
    },
    "done": { "terminal": true }
  }
}
