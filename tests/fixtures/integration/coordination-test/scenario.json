{
  "_description": "Synthetic multi-agent coordination test. Tests SC-004: HELD agent is held at startup, released within one signal cycle when FREE completes.",
  "_test_scenario": {
    "name": "two-ticket coordination: FREE and HELD",
    "tickets": ["FREE", "HELD"],
    "verifies": ["SC-004", "FR-009", "FR-010", "FR-011"]
  },
  "setup": {
    "FREE": {
      "has_coordination_json": false,
      "initial_state": {
        "current_step": "implement",
        "status": "running",
        "phase_history": []
      }
    },
    "HELD": {
      "has_coordination_json": true,
      "coordination_json": {"wait_for": {"id": "FREE", "phase": "implement"}},
      "initial_state": {
        "current_step": "implement",
        "status": "running",
        "phase_history": []
      }
    }
  },
  "simulation_steps": [
    {
      "step": 1,
      "action": "orchestrator_init",
      "description": "orchestrator-init.sh runs for session with tickets [FREE, HELD]",
      "expected_FREE_state": {
        "status": "running",
        "phase_command_sent": true
      },
      "expected_HELD_state": {
        "status": "held",
        "held_at": "implement",
        "waiting_for": "FREE:implement",
        "phase_command_sent": false
      }
    },
    {
      "step": 2,
      "action": "send_signal",
      "ticket": "FREE",
      "signal": "IMPLEMENT_COMPLETE",
      "description": "FREE completes implement phase",
      "expected_FREE_phase_history": [
        {"phase": "implement", "signal": "IMPLEMENT_COMPLETE"}
      ],
      "expected_FREE_state": {
        "status": "running",
        "current_step": "blindqa"
      }
    },
    {
      "step": 3,
      "action": "coordination_release_check",
      "description": "After FREE's IMPLEMENT_COMPLETE, collab.run.md scans for held agents. HELD's wait_for dep (FREE:implement) is now satisfied.",
      "expected_HELD_state": {
        "status": "running",
        "held_at": null,
        "waiting_for": null,
        "phase_command_sent": true
      }
    }
  ],
  "assertions": [
    {
      "id": "A1",
      "description": "HELD is in held state after orchestrator_init",
      "check": "registry['HELD'].status == 'held'"
    },
    {
      "id": "A2",
      "description": "HELD's held_at matches its first phase",
      "check": "registry['HELD'].held_at == 'implement'"
    },
    {
      "id": "A3",
      "description": "FREE phase command is sent at init",
      "check": "FREE agent pane receives implement command at startup"
    },
    {
      "id": "A4",
      "description": "HELD transitions from held → running within same signal-processing response as FREE's IMPLEMENT_COMPLETE",
      "check": "registry['HELD'].status == 'running' after step 2"
    },
    {
      "id": "A5",
      "description": "HELD's phase command sent after release",
      "check": "HELD agent pane receives implement command after FREE completes"
    }
  ]
}
